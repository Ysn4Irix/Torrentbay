{
  "expo": {
    "name": "TorrentBay",
    "slug": "torrentbay",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "torrentbay",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.torrentbay.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#05070C",
          "dark": { "backgroundColor": "#05070C" }
        }
      ],
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
