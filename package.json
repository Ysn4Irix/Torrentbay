{
  "name": "torrentbay",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{js,json}\" --check",
    "format:check": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{js,json}\" --check",
    "format:write": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{js,json}\" --write"
  },
  "dependencies": {
    "@expo/metro-runtime": "latest",
    "cheerio": "latest",
    "expo": "latest",
    "expo-constants": "latest",
    "expo-linking": "latest",
    "expo-router": "latest",
    "expo-status-bar": "latest",
    "lucide-react-native": "latest",
    "nativewind": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-native": "latest",
    "react-native-gesture-handler": "latest",
    "react-native-mmkv": "latest",
    "react-native-reanimated": "latest",
    "react-native-safe-area-context": "latest",
    "react-native-screens": "latest",
    "react-native-svg": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "latest",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  }
}
