{
  "name": "torrentbay",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "bun test",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{js,json}\" --check",
    "format:check": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{js,json}\" --check",
    "format:write": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{js,json}\" --write"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.3",
    "cheerio": "latest",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "lucide-react-native": "latest",
    "nativewind": "latest",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-mmkv": "latest",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "zustand": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "~19.2.4",
    "eslint": "^9.0.0",
    "eslint-config-expo": "latest",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.3"
  }
}
